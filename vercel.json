{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bash vercel-build.sh",
  "outputDirectory": "build/web",
  "redirects": [
    {
      "source": "/v/:path*",
      "destination": "https://vixrex-public.vercel.app/v/:path*",
      "permanent": false
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://vixrex-public.vercel.app/sitemap.xml",
      "permanent": false
    },
    {
      "source": "/robots.txt",
      "destination": "https://vixrex-public.vercel.app/robots.txt",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/main.dart.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/flutter_bootstrap.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/flutter_service_worker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/deploy-info.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
